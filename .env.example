# Sanity — projectId + dataset are PUBLIC ("project IDs are not secret"), but
# read from env (nuxt.config.ts). Set per project; required at build (local + Vercel).
NUXT_PUBLIC_SANITY_PROJECT_ID=your-project-id
NUXT_PUBLIC_SANITY_DATASET=production

# Resend — fill from resend.com → API Keys
# Server-side only (no NUXT_PUBLIC_ prefix) — never ships to the browser.
RESEND_API_KEY=

# Where contact form submissions land. Per-client this becomes their inbox.
CONTACT_TO_EMAIL=hi@bamoj.com

# SEO / AEO — set per client project. NUXT_PUBLIC_SITE_URL is the one knob
# that drives every absolute URL (sitemap entries, canonical tags, og:url,
# schema.org URLs, llms.txt). See .claude/skills/seo/SKILL.md.
NUXT_PUBLIC_SITE_URL=http://localhost:3000
NUXT_PUBLIC_SITE_NAME=Studio•Bamo.J®
NUXT_PUBLIC_SITE_DESCRIPTION=A creative studio building distinctive digital experiences with motion, type, and WebGL.

# Social URLs — uncomment and set per client for schema.org sameAs links.
# NUXT_PUBLIC_INSTAGRAM=https://instagram.com/...
# NUXT_PUBLIC_TWITTER=https://twitter.com/...
# NUXT_PUBLIC_LINKEDIN=https://linkedin.com/company/...
